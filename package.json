{
  "name": "sprint-tracker",
  "version": "1.0.0",
  "description": "personal sprint and pull request tracking application",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "lint": "pnpm eslint .",
    "clean": "rm -r -fo dist",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "copy:assets": "cp -r -fo static dist/static",
    "build:client": "tsc -p tsconfig.json && vite build",
    "build:server": "tsc -p server/tsconfig.json && pnpm run copy:assets",
    "build": "pnpm run build:client && pnpm run build:server",
    "start:server": "node dist/server/index.js",
    "electron": "tsc -p electron/tsconfig.json && electron dist/electron/main.js",
    "electron:rebuild": "electron-rebuild -f -w .",
    "db:run-sql": "node data/run-sql-file.mjs",
    "db:clear": "node data/clear-database.mjs",
    "db:load:test": "node data/run-sql-file.mjs testing_data.sql",
    "db:load:historical": "node data/run-sql-file.mjs existing_history.sql",
    "db:dump": "node data/dump-database.mjs",
    "test": "pnpm run test:unit && pnpm run test:integration && pnpm run test:e2e",
    "test:unit": "vitest run -c vitest.unit.config.ts",
    "test:unit:watch": "vitest -c vitest.unit.config.ts",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:integration:watch": "vitest -c vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "electron": "^43.1.0",
    "express": "^5.2.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.17.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@electron/rebuild": "^4.2.0",
    "eslint": "^10.6.0",
    "jsdom": "^29.1.1",
    "supertest": "^7.2.2",
    "tsx": "^4.23.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
