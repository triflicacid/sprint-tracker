# Port the Express server listens on. Defaults to 4000 if unset.
PORT=4000

# Filesystem path to the sqlite3 database file. Defaults to
# data/sprint-tracker.sqlite3 (relative to the process's cwd) if unset.
DB_PATH=data/sprint-tracker.sqlite3

# Base URL of your Jira instance. Required (along with JIRA_EMAIL and
# JIRA_API_TOKEN) for the optional Jira issue lookup feature - if any of the
# three are unset, GET /api/jira/:key just 404s and the rest of the app is
# unaffected.
JIRA_BASE_URL=https://your-domain.atlassian.net

# Email address of the Jira account used for basic auth against the Jira API.
JIRA_EMAIL=you@example.com

# API token for the Jira account above, used for basic auth. Create one at
# https://id.atlassian.com/manage-profile/security/api-tokens.
JIRA_API_TOKEN=your-jira-api-token

# Overrides the target the Vite dev client proxies /api requests to. Only
# needed to point the dev server at a non-default backend - e.g. the
# Playwright e2e suite uses this to target its own throwaway-db server
# instance instead of the one on PORT above.
VITE_API_PROXY_TARGET=http://localhost:4000

# Selects Electron's dev vs. production code path (dev expects dev:server /
# dev:client already running separately instead of starting an in-process
# server). Leave unset (or anything other than "development") for production
# behavior.
NODE_ENV=development
